# This file is used for local CLI tests.
#
# Copy it to ".env.test" and fill in values:
#   cp .env.test.example .env.test
#
# NOTE:
# - Tests will read APPID/APPSECRET from ".env.test" (if present) and map them
#   to the CLI env vars: WEIXINMP_APPID / WEIXINMP_SECRET.
# - For unit tests (with mocked HTTP server), dummy values are fine.

# APPID: WeChat Official Account (Weixin MP) AppID.
APPID=your_appid_here

# APPSECRET: WeChat Official Account (Weixin MP) AppSecret.
APPSECRET=your_app_secret_here

